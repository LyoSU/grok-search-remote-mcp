# Required: xAI API key from https://console.x.ai/
XAI_API_KEY=xai-your-key-here

# Optional: Grok model (default: grok-4.20-beta-latest-reasoning)
# Available: grok-4.20-beta-latest-reasoning, grok-4, grok-4-fast, grok-4-1-fast, grok-3
GROK_MODEL=grok-4.20-beta-latest-reasoning

# Optional: port (default: 3000)
PORT=3000
